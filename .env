# Postgres
POSTGRES_USER=pixik
POSTGRES_PASSWORD=pixikpass2025
POSTGRES_HOST=booking-service-db
POSTGRES_PORT=5432
POSTGRES_DB_NAME=booking-db
STORAGE_DSN=postgres://pixik:pixikpass2025@booking-service-db:5432/booking-db?sslmode=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=5
POSTGRES_MAX_CONN_LIFE_TIME=1h

# goose
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://pixik:pixikpass2025@booking-service-db:5432/booking-db?sslmode=disable
GOOSE_MIGRATION_DIR=./migrations

# HTTP
HTTP_PORT=8080
HTTP_IDLE_TIMEOUT=30s
HTTP_RATE_LIMITER_MAX_RPC=10000
HTTP_RATE_LIMITER_RPC_REFILL=10000

# JWT
JWT_SECRET=pixik-secret
JWT_EXPIRATION=24h

